---
// Import your data and the new component at the top of the file
import careerData from '../data/career.json';
import CareerCard from './career-card.astro';

const visibleCareerItems = 4;
const hasEarlierRoles = careerData.length > visibleCareerItems;
---

<section id="career" class="section-container max-w-6xl mx-auto overflow-hidden">
  <div class="container mx-auto reveal-content" style="animation-delay: 1000ms;">
    <div>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext mb-2 flex items-center gap-4">
        <span class="text-accent">/</span> Career
      </h2>
      <p class="text-subtext font-body text-sm max-w-md pb-8">
        A brief overview of my career
      </p>
    </div>

    <div class="relative">
      {/* Vertical Line*/}
      <div class="absolute left-2 md:left-1/2 md:-translate-x-1/2 top-5 bottom-0 w-0.5 bg-linear-to-b from-accent via-white/10 to-transparent"></div>

      {/* Mobile View */}
      <div class="md:hidden space-y-8">
        {careerData.map((item, index) => (
          <div class={`scroll-stat career-entry relative pl-6 ${index >= visibleCareerItems ? 'career-extra hidden' : ''}`}>
            {/* Dot for mobile view*/}
            <div class="absolute left-0 top-1 z-10">
              <div class={`w-4 h-4 rounded-full border-4 border-[#0a0a0a] 
                          ${index === 0 ? 'bg-accent shadow-[0_0_15px_var(--color-accent)] animate-pulse' : 'bg-accent/50'}`}>
              </div>
            </div>
            
            <CareerCard item={item} variant="mobile" />
          </div>
        ))}
      </div>

      {/* Desktop View */}
      <div class="hidden md:block space-y-4">
        {careerData.map((item, index) => (
          <div class={`scroll-stat career-entry relative grid grid-cols-2 ${index >= visibleCareerItems ? 'career-extra hidden' : ''}`}>
            {/* Center Dot */}
            <div class="absolute left-1/2 -translate-x-1/2 top-1 z-10">
              <div class={`w-4 h-4 rounded-full border-4 border-[#0a0a0a] 
                          ${index === 0 ? 'bg-accent shadow-[0_0_15px_var(--color-accent)] animate-pulse' : 'bg-accent/50'}`}>
              </div>
            </div>

            {/* Left Side (even items) */}
            <div class="md:px-6 md:py-0">
              {index % 2 === 0 ? (
                <CareerCard item={item} variant="desktop-left" />
              ) : <div class="h-full pointer-events-none"></div>}
            </div>

            {/* Right Side (odd items) */}
            <div class="md:px-6 md:py-0">
              {index % 2 !== 0 ? (
                <CareerCard item={item} variant="desktop-right" />
              ) : <div class="h-full pointer-events-none"></div>}
            </div>
          </div>
        ))}
      </div>
    </div>

    {hasEarlierRoles && (
      <div class="mt-10 flex justify-center">
        <button
          id="career-toggle"
          type="button"
          aria-expanded="false"
          class="group relative inline-flex items-center justify-center px-8 py-2 rounded-full border border-accent/30 bg-accent/5 text-maintext font-body text-sm transition-all duration-300 hover:border-accent/60 hover:bg-accent/10 hover:scale-105 cursor-pointer"
          data-show-label="Show Earlier History"
        >
          <span>Show Earlier History</span>
          <div class="absolute inset-0 rounded-full blur-md bg-accent/20 -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        </button>
      </div>
    )}
  </div>
</section>

<style>
  /* Reveal whole section when website loads */
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Initial state of the card */
  .scroll-stat {
    opacity: 0;
    transform: translateY(20px) scale(0.95);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Revealed state while scrolling*/
  .scroll-stat.reveal {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  .career-extra.hidden {
    display: none;
  }
</style>

<script>
  function revealCards() {
    const cards = document.querySelectorAll('.scroll-stat');
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Add a slight delay based on the card's position to create a wave effect
          const index = Array.from(cards).indexOf(entry.target);
          setTimeout(() => {
            entry.target.classList.add('reveal');
          }, (index % 3) * 150); // Delay resets every row for a clean staggered look
          
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15, // Trigger when 15% of the card is visible
      rootMargin: '0px 0px -10px 0px' // Trigger slightly before it hits the viewport
    });

    cards.forEach(card => observer.observe(card));
  }

  // Runs on initial load
  revealCards();

  function setupCareerToggle() {
    const button = document.getElementById('career-toggle');
    if (!button) return;

    const label = button.querySelector('span');
    const extras = document.querySelectorAll('.career-extra');
    const careerSection = document.getElementById('career');
    const showLabel = button.dataset.showLabel || 'Show Earlier History';

    const collapseEarlierHistory = () => {
      extras.forEach((entry) => {
        entry.classList.add('hidden');
        entry.classList.remove('reveal');
      });

      button.hidden = false;
      button.setAttribute('aria-expanded', 'false');
      if (label) label.textContent = showLabel;
    };

    button.addEventListener('click', () => {
      button.setAttribute('aria-expanded', 'true');
      button.hidden = true;

      extras.forEach((entry) => {
        entry.classList.remove('hidden');
        entry.classList.add('reveal');
      });
    });

    window.addEventListener('scroll', () => {
      if (!careerSection || button.getAttribute('aria-expanded') !== 'true') return;

      const sectionTop = careerSection.getBoundingClientRect().top + window.scrollY;
      if (window.scrollY < sectionTop - 20) {
        collapseEarlierHistory();
      }
    }, { passive: true });
  }

  setupCareerToggle();
  
  // Necessary for Astro View Transitions if you use them
  document.addEventListener('astro:after-swap', () => {
    revealCards();
    setupCareerToggle();
  });
</script>
